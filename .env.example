# lualambda environment — copy to .env (gitignored) and fill in.
# NEVER put Algorand MAINNET keys here. Testnet only, throwaway keys only.

# --- Orchestrator / CLI ---
LUALAMBDA_ORCHESTRATOR_URL=http://localhost:8402
LUALAMBDA_PORT=8402
# Single writable working dir: pkg/, instances/<id>/ (with boot.log), runtime/.
# Defaults to ~/.local/share/lualambda. (LUALAMBDA_DATA_DIR still honored as an
# alias.) Set this to keep state in-project during dev:
LUALAMBDA_WORKDIR=.lualambda

# --- x402 / Algorand ---
# Payments are ENFORCED only when LUALAMBDA_PAY_TO is set; otherwise the
# orchestrator runs free (the dev/E2E path).
#
# Network selects a hardcoded bundle (CAIP-2 + USDC ASA + algod/explorer
# defaults). The USDC ASA ids are protocol constants, NOT configurable:
#   testnet -> ASA 10458941   mainnet -> ASA 31566704
LUALAMBDA_NETWORK=testnet
# Shared facilitator (routes by CAIP-2; same URL for both networks).
LUALAMBDA_FACILITATOR_URL=https://facilitator.goplausible.xyz
# Address that RECEIVES payments. IMPORTANT: it must be opted into the USDC ASA
# to hold it (run `lualambda wallet opt-in` from that account), or settlement
# fails. The orchestrator holds no key — the facilitator fee-sponsors.
LUALAMBDA_PAY_TO=
# Operational endpoints default per-network; override only if needed.
LUALAMBDA_ALGOD_URL=
LUALAMBDA_EXPLORER_TX_BASE=

# --- CLI wallet (client Algorand testnet key) ---
# Wallet file (default ~/.config/lualambda/wallet.json). LUALAMBDA_MNEMONIC,
# if set, overrides the file. Testnet throwaway keys only.
LUALAMBDA_WALLET=
LUALAMBDA_MNEMONIC=

# --- QEMU / guest ---
# Vendored artifacts are the defaults; override only for a custom build.
LUALAMBDA_KERNEL=vendor/micront/vmlinux
LUALAMBDA_INITRD_TEMPLATE=vendor/micront/initrd.zip
LUALAMBDA_QEMU=qemu-system-x86_64
