# lualambda environment — copy to .env (gitignored) and fill in.
# NEVER put Algorand MAINNET keys here. Testnet only, throwaway keys only.

# --- Orchestrator / CLI ---
LUALAMBDA_ORCHESTRATOR_URL=http://localhost:8402
LUALAMBDA_PORT=8402
LUALAMBDA_DATA_DIR=.lualambda/data

# --- x402 / Algorand (Milestone 2) ---
# CAIP-2 network id for Algorand testnet.
LUALAMBDA_ALGORAND_NETWORK=algorand:SGO1GKSzyE7IEPItTxCByw9x8FmnrCDexi9/cOUJOiI=
LUALAMBDA_FACILITATOR_URL=https://facilitator.goplausible.xyz
# Confirm the testnet USDC ASA id from the Algorand x402 docs before relying on it.
LUALAMBDA_USDC_ASA_ID=
# Orchestrator's AVM address that receives payments.
LUALAMBDA_PAY_TO=

# --- QEMU / guest (Milestone 0) ---
# Path to the MicroNT PVH kernel (vmlinux). Set once the spike has artifacts.
LUALAMBDA_KERNEL=
LUALAMBDA_QEMU=qemu-system-x86_64
