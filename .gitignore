# Dependencies
node_modules/

# Build output (Bun compiled binaries, etc.)
build/
dist/
*.tsbuildinfo

# Bun
.bun/

# Secrets — NEVER commit keys. Testnet or not.
.env
.env.*
!.env.example
*.key
*.pem
wallet.json
mnemonic.txt
secrets/

# Orchestrator runtime data (deployed bundles, metadata)
.lualambda/

# QEMU / VM artifacts (per-instance / scratch — NOT the vendored ones below)
*.img
*.qcow2
initrd.zip
*.log

# OS / editor cruft
.DS_Store

# Claude Code local (personal) settings — shared config goes in settings.json
.claude/settings.local.json

# Scratch dir for ad-hoc artifact drops / experiments.
tmp/

# Vendored MicroNT artifacts are version-controlled (small, no upstream release
# pipeline). Re-include them despite the *.img / initrd.zip rules above.
!vendor/
!vendor/micront/initrd.zip
